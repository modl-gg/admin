# Production environment configuration
# This file is used when running: npm run build

# API URL - Leave empty to use dynamic domain resolution:
# - admin.modl.gg -> api.modl.gg
# - admin.cobl.gg -> api.cobl.gg
# - .pages.dev domains -> fallback to MODL.Domain.HTTPS_API
# Set VITE_API_BASE_URL in Cloudflare Pages for .pages.dev preview deployments
VITE_API_BASE_URL=
